# Copy to .env and fill in. .env is gitignored.

# --- LLM ---
OPENAI_API_KEY=sk-...
AERORAG_CHAT_MODEL=gpt-4o-mini
AERORAG_EMBED_MODEL=text-embedding-3-small

# --- Storage ---
AERORAG_DATA_DIR=./data
AERORAG_CHROMA_DIR=./data/processed/chroma

# --- Retrieval ---
AERORAG_TOP_K=5
AERORAG_RERANK_TOP_K=25
AERORAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- App ---
AERORAG_LOG_LEVEL=INFO
